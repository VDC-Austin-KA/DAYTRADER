# Copy to .env for local development. Railway injects these as service variables.

# Postgres connection (Railway sets DATABASE_URL automatically when you add the plugin).
# Leave unset locally to use a bundled SQLite file.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

SECRET_KEY=change-me

# --- Market data: Tradier (REQUIRED for live data) ---
# Free token: sign up at https://developer.tradier.com -> create an app ->
# copy the Access Token. Sandbox works out of the box (delayed quotes, real chains).
TRADIER_TOKEN=
# Sandbox (default): https://sandbox.tradier.com/v1
# Production (real-time, needs a brokerage/funded token): https://api.tradier.com/v1
TRADIER_BASE_URL=https://sandbox.tradier.com/v1

# Train all watchlist models automatically on first startup
AUTO_TRAIN_ON_START=true

# Paper-trading starting balance
STARTING_CASH=100000

# Strategy / model tuning
MAX_DTE=30
MIN_DTE=1
SIGNAL_THRESHOLD=0.58
HORIZON_DAYS=3
TARGET_MOVE=0.01
HISTORY_YEARS=5

# Comma-separated universe to model and scan
WATCHLIST=SPY,QQQ,AAPL,MSFT,NVDA,TSLA,AMD,AMZN,META,GOOGL

# Background scheduler
ENABLE_SCHEDULER=true
REFRESH_MINUTES=30

# ---------------------------------------------------------------------------
# BTC hourly prediction-market bot
# ---------------------------------------------------------------------------
PREDICTION_BOT_ENABLED=true
# paper = simulate fills locally (default). live = route orders via moomoo OpenD.
PREDICTION_TRADE_MODE=paper
PREDICTION_CYCLE_SECONDS=60

# Contract discovery/quotes (moomoo prediction markets are Kalshi contracts;
# the public market-data API needs no key).
KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
PREDICTION_SERIES_TICKER=KXBTCD

# Strategy
PREDICTION_MIN_EDGE=0.06
PREDICTION_MOMENTUM_COEFF=0.35
PREDICTION_MIN_MINUTES_LEFT=8
PREDICTION_MAX_MINUTES_LEFT=55
PREDICTION_MIN_PRICE_CENTS=10
PREDICTION_MAX_PRICE_CENTS=90

# Risk management
PREDICTION_BANKROLL=1000
PREDICTION_KELLY_FRACTION=0.25
PREDICTION_MAX_STAKE_USD=100
PREDICTION_MAX_STAKE_PCT=0.10
PREDICTION_MAX_DAILY_LOSS=150
PREDICTION_MAX_OPEN=1
PREDICTION_MAX_CONSECUTIVE_LOSSES=4
PREDICTION_COOLDOWN_MINUTES=60

# moomoo OpenD gateway — required only for live mode. Run OpenD on a machine
# you control, log in AND unlock trading manually in its GUI (the SDK cannot
# and must not unlock trading), then point the app at it. Set these as Railway
# service variables; never commit real values.
# MOOMOO_OPEND_HOST=
# MOOMOO_OPEND_PORT=11111
# MOOMOO_TRD_ENV=SIMULATE
# MOOMOO_SECURITY_FIRM=FUTUINC
# MOOMOO_ACC_ID=0
# MOOMOO_CODE_PREFIX=US.
