# Copy to .env for local development. Railway injects these as service variables.

# Postgres connection (Railway sets DATABASE_URL automatically when you add the plugin).
# Leave unset locally to use a bundled SQLite file.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

SECRET_KEY=change-me

# --- Market data: Tradier (REQUIRED for live data) ---
# Free token: sign up at https://developer.tradier.com -> create an app ->
# copy the Access Token. Sandbox works out of the box (delayed quotes, real chains).
TRADIER_TOKEN=
# Sandbox (default): https://sandbox.tradier.com/v1
# Production (real-time, needs a brokerage/funded token): https://api.tradier.com/v1
TRADIER_BASE_URL=https://sandbox.tradier.com/v1

# Train all watchlist models automatically on first startup
AUTO_TRAIN_ON_START=true

# Paper-trading starting balance
STARTING_CASH=100000

# Strategy / model tuning
MAX_DTE=30
MIN_DTE=1
SIGNAL_THRESHOLD=0.58
HORIZON_DAYS=3
TARGET_MOVE=0.01
HISTORY_YEARS=5

# Comma-separated universe to model and scan
WATCHLIST=SPY,QQQ,AAPL,MSFT,NVDA,TSLA,AMD,AMZN,META,GOOGL

# Background scheduler
ENABLE_SCHEDULER=true
REFRESH_MINUTES=30
